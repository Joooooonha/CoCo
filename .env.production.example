COCO_DB_NAME=coco
COCO_DB_USER=coco
COCO_DB_PASSWORD=
CLOUDFLARE_TUNNEL_TOKEN=
COCO_PUBLIC_API_BASE_URL=https://api.example.com
COCO_API_IMAGE=ghcr.io/joooooonha/coco-api:latest
COCO_MANAGEMENT_PORT=19090

COCO_DB_POOL_MAX_SIZE=10
COCO_DB_POOL_MIN_IDLE=2
COCO_HTTP_MAX_REQUEST_BODY_BYTES=262144
COCO_TOMCAT_MAX_THREADS=50
COCO_TOMCAT_MIN_SPARE_THREADS=5
COCO_TOMCAT_MAX_QUEUE_CAPACITY=50
COCO_TOMCAT_MAX_CONNECTIONS=200
COCO_TOMCAT_ACCEPT_COUNT=50

COCO_API_MEMORY_LIMIT=768m
COCO_API_CPU_LIMIT=1.5
COCO_POSTGRES_MEMORY_LIMIT=768m
COCO_POSTGRES_CPU_LIMIT=1.0
